  calculated_at      DateTime   @default(now()) @db.Timestamptz(6)
  created_at         DateTime   @default(now()) @db.Timestamptz(6)
  updated_at         DateTime   @default(now()) @db.Timestamptz(6)
  businesses         businesses @relation(fields: [business_id], references: [id], onDelete: Cascade)
  products           products   @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([business_id, product_id, period_days], map: "idx_inventory_abc_business_product_period")
  @@index([business_id, abc_category], map: "idx_inventory_abc_business_category")
}

model cycle_counts {
  id                    String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id           String                  @db.Uuid
  name                  String                  @db.VarChar(255)
  category              String                  @default("manual") @db.VarChar(64)
  warehouse_id          String?                 @db.Uuid
  status                String                  @default("in-progress") @db.VarChar(32)
  item_count            Int                     @default(0)
  variance_count        Int                     @default(0)
  scheduled_date        DateTime?               @db.Date
  completed_at          DateTime?               @db.Timestamptz(6)
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                @default(now()) @db.Timestamptz(6)
  businesses            businesses              @relation(fields: [business_id], references: [id], onDelete: Cascade)
  warehouse_locations   warehouse_locations?    @relation(fields: [warehouse_id], references: [id], onDelete: SetNull)
  cycle_count_items     cycle_count_items[]
  inventory_adjustments inventory_adjustments[]

  @@index([business_id, status, created_at(sort: Desc)], map: "idx_cycle_counts_business_status")
}

model cycle_count_items {
  id               String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cycle_count_id   String       @db.Uuid
  product_id       String       @db.Uuid
  sku              String?      @db.VarChar(120)
  product_name     String       @db.VarChar(255)
  system_quantity  Decimal      @default(0) @db.Decimal(12, 2)
  counted_quantity Decimal?     @db.Decimal(12, 2)
  unit_price       Decimal      @default(0) @db.Decimal(12, 2)
  created_at       DateTime     @default(now()) @db.Timestamptz(6)
  updated_at       DateTime     @default(now()) @db.Timestamptz(6)
  cycle_counts     cycle_counts @relation(fields: [cycle_count_id], references: [id], onDelete: Cascade)
  products         products     @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([cycle_count_id, product_id], map: "idx_cycle_count_items_unique_product")
  @@index([cycle_count_id], map: "idx_cycle_count_items_count")
}

model inventory_adjustments {
  id             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cycle_count_id String?       @db.Uuid
  product_id     String        @db.Uuid
  adjustment_qty Decimal       @db.Decimal(12, 2)
  reason         String?
  created_at     DateTime      @default(now()) @db.Timestamptz(6)
  cycle_counts   cycle_counts? @relation(fields: [cycle_count_id], references: [id], onDelete: SetNull)
  products       products      @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id, created_at(sort: Desc)], map: "idx_inventory_adjustments_product_date")
}

// ─── Bank reconciliation tables ───────────────────────────────────────────────
// Tables created by prisma/migrations/20260514_bank_reconciliation

model bank_reconciliation_sessions {
  id                        String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id               String                 @db.Uuid
  account_id                String                 @db.Uuid
  statement_date            DateTime               @db.Date
  statement_closing_balance Decimal                @default(0) @db.Decimal(15, 2)
  status                    String                 @default("in_progress")
  completed_at              DateTime?              @db.Timestamptz(6)
  created_by                String?
  created_at                DateTime               @default(now()) @db.Timestamptz(6)
  updated_at                DateTime               @default(now()) @db.Timestamptz(6)
  businesses                businesses             @relation(fields: [business_id], references: [id], onDelete: Cascade)
  gl_accounts               gl_accounts            @relation(fields: [account_id], references: [id])
  bank_statement_lines      bank_statement_lines[]

  @@unique([business_id, account_id, statement_date], map: "uidx_bank_recon_sessions_unique")
  @@index([business_id], map: "idx_bank_recon_sessions_business_id")
  @@index([account_id, statement_date], map: "idx_bank_recon_sessions_account_date")
}

model bank_statement_lines {
  id                           String                       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  session_id                   String                       @db.Uuid
  statement_date               DateTime                     @db.Date
  description                  String?
  debit                        Decimal                      @default(0) @db.Decimal(15, 2)
  credit                       Decimal                      @default(0) @db.Decimal(15, 2)
  matched                      Boolean                      @default(false)
  gl_entry_id                  String?                      @db.Uuid
  created_at                   DateTime                     @default(now()) @db.Timestamptz(6)
  bank_reconciliation_sessions bank_reconciliation_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)
  gl_entries                   gl_entries?                  @relation(fields: [gl_entry_id], references: [id], onDelete: SetNull)

  @@index([session_id], map: "idx_bank_stmt_lines_session_id")
  @@index([session_id, matched], map: "idx_bank_stmt_lines_matched")
  @@index([gl_entry_id], map: "idx_bank_stmt_lines_gl_entry")
}

// ═══════════════════════════════════════════════════════════════════════
// Tenant customer memberships (gym/spa/salon access plans — not platform SaaS)
// ═══════════════════════════════════════════════════════════════════════

/// Sellable plan catalog — typically linked to a membership product SKU.
model membership_plans {
  id               String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String                 @db.Uuid
  product_id       String?                @db.Uuid
  vertical_key     String                 @db.VarChar(64)
  name             String
  slug             String?
  billing_interval String                 @default("monthly") @db.VarChar(32) // monthly | quarterly | annual | session_pack | installment | none
  duration_days    Int?
  price            Decimal                @default(0) @db.Decimal(12, 2)
  compare_price    Decimal?               @db.Decimal(12, 2)
  currency         String                 @default("PKR") @db.VarChar(10)
  domain_rules     Json?                  @default("{}")
  is_active        Boolean                @default(true)
  metadata         Json?                  @default("{}")
  created_at       DateTime               @default(now()) @db.Timestamptz(6)
  updated_at       DateTime               @default(now()) @updatedAt @db.Timestamptz(6)
  businesses       businesses             @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products         products?              @relation(fields: [product_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  enrollments      customer_memberships[]
  benefits         membership_benefits[]

  @@unique([business_id, product_id], map: "membership_plans_business_product_key")
  @@index([business_id, vertical_key, is_active], map: "idx_membership_plans_business_vertical")
  @@index([business_id, slug], map: "idx_membership_plans_business_slug")
}

/// Active or historical customer enrollment in a membership plan.
model customer_memberships {
  id                     String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id            String              @db.Uuid
  customer_id            String              @db.Uuid
  plan_id                String              @db.Uuid
  product_id             String?             @db.Uuid
  status                 String              @default("pending") @db.VarChar(32) // trial | pending | active | paused | cancelled | expired
  started_at             DateTime            @default(now()) @db.Timestamptz(6)
  ends_at                DateTime?           @db.Timestamptz(6)
  next_billing_at        DateTime?           @db.Timestamptz(6)
  auto_renew             Boolean             @default(true)
  source                 String              @default("hub") @db.VarChar(32) // storefront | pos | hub | import
  initial_storefront_order_id Int?
  initial_pos_transaction_id String?        @db.Uuid
  initial_invoice_id     String?             @db.Uuid
  recurring_invoice_id   String?             @db.Uuid
  amount_paid            Decimal?            @default(0) @db.Decimal(12, 2)
  domain_data            Json?               @default("{}")
  cancelled_at           DateTime?           @db.Timestamptz(6)
  paused_at              DateTime?           @db.Timestamptz(6)
  created_at             DateTime            @default(now()) @db.Timestamptz(6)
  updated_at             DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  businesses             businesses          @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  customers              customers           @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  plan                   membership_plans    @relation(fields: [plan_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  initial_invoice        invoices?           @relation("MembershipInitialInvoice", fields: [initial_invoice_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  recurring_invoice      invoices?           @relation("MembershipRecurringInvoice", fields: [recurring_invoice_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  events                 membership_events[]

  @@index([business_id, customer_id, status], map: "idx_customer_memberships_business_customer_status")
  @@index([business_id, ends_at], map: "idx_customer_memberships_business_ends")
  @@index([business_id, next_billing_at], map: "idx_customer_memberships_business_next_billing")
  @@index([business_id, plan_id], map: "idx_customer_memberships_business_plan")
}

model membership_events {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id   String               @db.Uuid
  membership_id String               @db.Uuid
  event_type    String               @db.VarChar(64)
  metadata      Json?                @default("{}")
  created_at    DateTime             @default(now()) @db.Timestamptz(6)
  businesses    businesses           @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  membership    customer_memberships @relation(fields: [membership_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([membership_id, created_at(sort: Desc)], map: "idx_membership_events_membership_created")
  @@index([business_id, event_type], map: "idx_membership_events_business_type")
}

model membership_benefits {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id  String           @db.Uuid
  plan_id      String           @db.Uuid
  benefit_type String           @db.VarChar(64) // discount_percent | loyalty_multiplier | price_list | class_credits
  value        Json             @default("{}")
  is_active    Boolean          @default(true)
  created_at   DateTime         @default(now()) @db.Timestamptz(6)
  updated_at   DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  businesses   businesses       @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  plan         membership_plans @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([business_id, plan_id], map: "idx_membership_benefits_business_plan")
}
