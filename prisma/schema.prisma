  created_at   DateTime   @default(now()) @db.Timestamptz(6)
  updated_at   DateTime   @default(now()) @db.Timestamptz(6)
  businesses   businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([business_id])
  @@index([vendor_id])
}

model price_lists {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id String             @db.Uuid
  name        String
  description String?
  currency    String             @default("PKR")
  is_active   Boolean            @default(true)
  created_at  DateTime           @default(now()) @db.Timestamptz(6)
  updated_at  DateTime           @default(now()) @db.Timestamptz(6)
  businesses  businesses         @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  items       price_list_items[]

  @@index([business_id])
}

model price_list_items {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id   String?     @db.Uuid
  price_list_id String      @db.Uuid
  product_id    String      @db.Uuid
  price         Decimal     @db.Decimal(12, 2)
  min_quantity  Decimal     @default(1) @db.Decimal(12, 2)
  businesses    businesses? @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  price_lists   price_lists @relation(fields: [price_list_id], references: [id], onDelete: Cascade)
  products      products    @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([price_list_id, product_id])
  @@index([business_id], map: "idx_price_list_items_business_id")
}

// ═══════════════════════════════════════════════════════════════════════
// FINANCE MODULE — Journal Entries, Fiscal Periods, Expenses
// ═══════════════════════════════════════════════════════════════════════

model journal_entries {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String            @db.Uuid
  journal_number   String?           @db.VarChar(50)
  transaction_date DateTime          @db.Date
  description      String?
  reference_type   String?           @db.VarChar(50)
  reference_id     String?           @db.Uuid
  reference_number String? // free-text reference entered by users (e.g. cheque no., doc no.)
  is_reversed      Boolean           @default(false)
  reversed_by      String?           @db.Uuid
  created_by       String?           @db.VarChar(255)
  status           String            @default("posted") @db.VarChar(20) // draft | posted | reversed
  created_at       DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?         @default(now()) @db.Timestamptz(6)
  businesses       businesses        @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  gl_entries       gl_entries[]
  reversal_source  journal_entries?  @relation("journal_reversal", fields: [reversed_by], references: [id], onUpdate: NoAction)
  reversed_entries journal_entries[] @relation("journal_reversal")

  @@unique([business_id, journal_number])
  @@index([business_id])
  @@index([business_id, transaction_date(sort: Desc)])
  @@index([reference_type, reference_id])
  @@index([business_id, status])
}

model fiscal_periods {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id   String     @db.Uuid
  name          String     @db.VarChar(100)
  start_date    DateTime   @db.Date
  end_date      DateTime   @db.Date
  status        String     @default("open") @db.VarChar(20)
  closed_by     String?    @db.VarChar(255)
  closed_at     DateTime?  @db.Timestamptz(6)
  closing_notes String?
  created_at    DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?  @default(now()) @db.Timestamptz(6)
  businesses    businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([business_id, start_date, end_date])
  @@index([business_id])
  @@index([business_id, status])
}

model payment_allocations {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id String     @db.Uuid
  payment_id  String     @db.Uuid
  /// [XOR] Must have either invoice_id or purchase_id, but not both.
  invoice_id  String?    @db.Uuid
  /// [XOR] Must have either invoice_id or purchase_id, but not both.
  purchase_id String?    @db.Uuid
  amount      Decimal    @db.Decimal(12, 2)
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)
  payments    payments   @relation(fields: [payment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  invoices    invoices?  @relation(fields: [invoice_id], references: [id], onUpdate: NoAction)
  purchases   purchases? @relation(fields: [purchase_id], references: [id], onUpdate: NoAction)

  @@index([payment_id])
  @@index([invoice_id])
  @@index([purchase_id])
}

model expenses {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id    String      @db.Uuid
  expense_number String?     @db.VarChar(50)
  account_id     String      @db.Uuid
  category       String?     @db.VarChar(100)
  amount         Decimal     @db.Decimal(12, 2)
  tax_amount     Decimal?    @default(0) @db.Decimal(12, 2)
  vendor_id      String?     @db.Uuid
  payment_method String?     @default("cash") @db.VarChar(50)
  date           DateTime    @db.Date
  description    String?
  receipt_url    String?
  status         String      @default("recorded") @db.VarChar(20)
  is_deleted     Boolean     @default(false)
  deleted_at     DateTime?   @db.Timestamptz(6)
  created_at     DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?   @default(now()) @db.Timestamptz(6)
  businesses     businesses  @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  gl_accounts    gl_accounts @relation(fields: [account_id], references: [id], onUpdate: NoAction)
  vendors        vendors?    @relation(fields: [vendor_id], references: [id], onUpdate: NoAction)

  /// Active-row uniqueness when expense_number is set: partial unique index
  @@index([business_id, expense_number])
  @@index([business_id])
  @@index([business_id, date(sort: Desc)])
  @@index([business_id, category])
  @@index([is_deleted])
}

model exchange_rates {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id    String     @db.Uuid
  from_currency  String     @db.VarChar(3)
  to_currency    String     @db.VarChar(3)
  rate           Decimal    @db.Decimal(18, 8)
  effective_date DateTime   @db.Date
  source         String?    @default("manual") @db.VarChar(50)
  created_at     DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?  @default(now()) @db.Timestamptz(6)
  businesses     businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([business_id, from_currency, to_currency, effective_date])
  @@index([business_id])
}

model credit_notes {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id           String              @db.Uuid
  credit_note_number    String              @db.VarChar(50)
  invoice_id            String?             @db.Uuid
  customer_id           String?             @db.Uuid
  date                  DateTime            @db.Date
  subtotal              Decimal?            @default(0) @db.Decimal(12, 2)
  tax_amount            Decimal?            @default(0) @db.Decimal(12, 2)
  total_amount          Decimal             @db.Decimal(12, 2)
  reason                String?
  status                String              @default("draft") @db.VarChar(20)
  applied_to_invoice_id String?             @db.Uuid
  created_at            DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?           @default(now()) @db.Timestamptz(6)
  businesses            businesses          @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  invoices              invoices?           @relation(fields: [invoice_id], references: [id], onUpdate: NoAction)
  customers             customers?          @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  credit_note_items     credit_note_items[]

  @@unique([business_id, credit_note_number])
  @@index([business_id])
  @@index([invoice_id])
  @@index([customer_id])
}

model credit_note_items {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id    String?      @db.Uuid
  credit_note_id String       @db.Uuid
  product_id     String?      @db.Uuid
  description    String?
  quantity       Decimal      @default(1) @db.Decimal(12, 2)
  unit_price     Decimal      @default(0) @db.Decimal(12, 2)
  tax_amount     Decimal?     @default(0) @db.Decimal(12, 2)
  total_amount   Decimal?     @default(0) @db.Decimal(12, 2)
  created_at     DateTime?    @default(now()) @db.Timestamptz(6)
  businesses     businesses?  @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  credit_notes   credit_notes @relation(fields: [credit_note_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products       products?    @relation(fields: [product_id], references: [id], onUpdate: NoAction)

  @@index([business_id], map: "idx_credit_note_items_business_id")
  @@index([credit_note_id])
  @@index([product_id])
}

// ═══════════════════════════════════════════════════════════════════════
// POS MODULE — Terminals, Sessions, Transactions
// ═══════════════════════════════════════════════════════════════════════

model pos_terminals {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id     String               @db.Uuid
  name            String               @db.VarChar(100)
  code            String?              @db.VarChar(20)
  warehouse_id    String?              @db.Uuid
  status          String               @default("active") @db.VarChar(20)
  hardware_config Json?                @default("{}")
  created_at      DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?            @default(now()) @db.Timestamptz(6)
  businesses      businesses           @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  warehouse       warehouse_locations? @relation(fields: [warehouse_id], references: [id], onUpdate: NoAction)
  pos_sessions    pos_sessions[]

  @@unique([business_id, code])
  @@index([business_id])
}

model pos_sessions {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String             @db.Uuid
  terminal_id      String             @db.Uuid
  user_id          String
  opening_balance  Decimal            @default(0) @db.Decimal(12, 2)
  closing_balance  Decimal?           @db.Decimal(12, 2)
  expected_balance Decimal?           @db.Decimal(12, 2)
  difference       Decimal?           @db.Decimal(12, 2)
  status           String             @default("open") @db.VarChar(20)
  opened_at        DateTime?          @default(now()) @db.Timestamptz(6)
  closed_at        DateTime?          @db.Timestamptz(6)
  notes            String?
  businesses       businesses         @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pos_terminals    pos_terminals      @relation(fields: [terminal_id], references: [id], onUpdate: NoAction)
  user             User               @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  pos_transactions pos_transactions[]

  @@index([business_id])
  @@index([terminal_id])
  @@index([status])
}

model pos_transactions {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id           String                  @db.Uuid
  session_id            String                  @db.Uuid
  transaction_number    String                  @db.VarChar(50)
  customer_id           String?                 @db.Uuid
  invoice_id            String?                 @db.Uuid // C18: Link to formal invoice if converted
  subtotal              Decimal                 @db.Decimal(12, 2)
  tax_amount            Decimal?                @default(0) @db.Decimal(12, 2)
  discount_amount       Decimal?                @default(0) @db.Decimal(12, 2)
  total_amount          Decimal                 @db.Decimal(12, 2)
  payment_status        String                  @default("completed") @db.VarChar(20)
  transaction_type      String                  @default("sale") @db.VarChar(20)
  is_voided             Boolean                 @default(false)
  voided_by             String?
  voided_at             DateTime?               @db.Timestamptz(6)
  void_reason           String?
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  businesses            businesses              @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pos_sessions          pos_sessions            @relation(fields: [session_id], references: [id], onUpdate: NoAction)
  customers             customers?              @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  invoices              invoices?               @relation(fields: [invoice_id], references: [id], onUpdate: NoAction)
  pos_transaction_items pos_transaction_items[]
  pos_payments          pos_payments[]
  pos_refunds           pos_refunds[]

  @@unique([business_id, transaction_number])
  @@index([business_id])
  @@index([session_id])
  @@index([invoice_id])
  @@index([business_id, created_at(sort: Desc)])
}

model pos_transaction_items {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String?          @db.Uuid
  transaction_id   String           @db.Uuid
  product_id       String           @db.Uuid
  variant_id       String?          @db.Uuid
  batch_id         String?          @db.Uuid
  serial_number    String?          @db.VarChar(255)
  quantity         Decimal          @db.Decimal(12, 2)
  unit_price       Decimal          @db.Decimal(12, 2)
  discount_amount  Decimal?         @default(0) @db.Decimal(12, 2)
  tax_amount       Decimal?         @default(0) @db.Decimal(12, 2)
  total_amount     Decimal          @db.Decimal(12, 2)
  promotion_id     String?          @db.Uuid
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  businesses       businesses?      @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pos_transactions pos_transactions @relation(fields: [transaction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products         products         @relation(fields: [product_id], references: [id], onUpdate: NoAction)

  @@index([business_id], map: "idx_pos_tx_items_business_id")
  @@index([transaction_id])
  @@index([product_id])
}

model pos_payments {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String?          @db.Uuid
  transaction_id   String           @db.Uuid
  method           String           @db.VarChar(50)
  amount           Decimal          @db.Decimal(12, 2)
  reference        String?          @db.VarChar(255)
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  businesses       businesses?      @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pos_transactions pos_transactions @relation(fields: [transaction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([business_id], map: "idx_pos_payments_business_id")
  @@index([transaction_id])
}

// ─── Phase 3: POS Enhancement ───────────────────────────────────────────────

model pos_refunds {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String             @db.Uuid
  transaction_id   String             @db.Uuid
  refund_number    String             @db.VarChar(50)
  refund_type      String             @default("full") @db.VarChar(20) // full | partial | exchange
  reason           String?
  subtotal         Decimal            @db.Decimal(12, 2)
  tax_amount       Decimal?           @default(0) @db.Decimal(12, 2)
  total_amount     Decimal            @db.Decimal(12, 2)
  refund_method    String             @default("cash") @db.VarChar(20) // cash | card | store_credit
  status           String             @default("completed") @db.VarChar(20)
  processed_by     String?
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  businesses       businesses         @relation(fields: [business_id], references: [id], onDelete: Cascade)
  pos_transactions pos_transactions   @relation(fields: [transaction_id], references: [id])
  pos_refund_items pos_refund_items[]

  @@unique([business_id, refund_number])
  @@index([business_id])
  @@index([transaction_id])
}

model pos_refund_items {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id   String?     @db.Uuid
  refund_id     String      @db.Uuid
  product_id    String?     @db.Uuid
  product_name  String
  quantity      Decimal     @db.Decimal(12, 2)
  unit_price    Decimal     @db.Decimal(12, 2)
  refund_amount Decimal     @db.Decimal(12, 2)
  restock       Boolean     @default(true)
  created_at    DateTime?   @default(now()) @db.Timestamptz(6)
  businesses    businesses? @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pos_refunds   pos_refunds @relation(fields: [refund_id], references: [id], onDelete: Cascade)

  @@index([business_id], map: "idx_pos_refund_items_business_id")
  @@index([refund_id])
}

model loyalty_programs {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id          String                 @db.Uuid
  name                 String                 @db.VarChar(100)
  points_per_amount    Decimal                @default(1) @db.Decimal(8, 2) // points earned per currency unit spent
  currency_per_point   Decimal                @default(1) @db.Decimal(8, 2) // currency value per point redeemed
  min_redeem_points    Int                    @default(100)
  is_active            Boolean                @default(true)
  created_at           DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?              @default(now()) @db.Timestamptz(6)
  businesses           businesses             @relation(fields: [business_id], references: [id], onDelete: Cascade)
  loyalty_transactions loyalty_transactions[]

  @@index([business_id])
}

model loyalty_transactions {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String           @db.Uuid
  program_id       String           @db.Uuid
  customer_id      String           @db.Uuid
  type             String           @db.VarChar(20) // earn | redeem | adjust | expire
  points           Int
  reference_type   String?          @db.VarChar(50) // pos_transaction | manual
  reference_id     String?          @db.Uuid
  balance_after    Int              @default(0)
  description      String?
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  businesses       businesses       @relation(fields: [business_id], references: [id], onDelete: Cascade)
  loyalty_programs loyalty_programs @relation(fields: [program_id], references: [id])
  customers        customers        @relation(fields: [customer_id], references: [id])

  @@index([business_id])
  @@index([customer_id])
  @@index([program_id])
}

// ─── Phase 5: Restaurant Vertical ───────────────────────────────────────────

model restaurant_tables {
