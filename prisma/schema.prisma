generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String              @id
  name              String
  email             String              @unique
  emailVerified     Boolean             @default(false)
  image             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  banExpires        DateTime?
  banReason         String?
  banned            Boolean?            @default(false)
  displayUsername   String?
  lastLoginMethod   String?
  role              String?
  stripeCustomerId  String?
  twoFactorEnabled  Boolean?            @default(false)
  username          String?             @unique
  accounts          Account[]
  business_users    business_users[]
  businesses        businesses[]
  sessions          Session[]
  twofactors        TwoFactor[]
  pos_sessions      pos_sessions[]
  invoice_approvals invoice_approvals[] @relation("invoice_approvals")
  invoice_templates invoice_templates[] @relation("invoice_templates")
  invoices_created  invoices[]          @relation("invoices_created_by")

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id          String @id
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

model boms {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id       String              @db.Uuid
  name              String
  product_id        String              @db.Uuid
  output_quantity   Decimal?            @default(1) @db.Decimal(12, 2)
  notes             String?
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?           @default(now()) @db.Timestamptz(6)
  domain_data       Json?               @default("{}")
  version           String?             @default("1.0") @db.VarChar(20)
  bom_materials     bom_materials[]
  businesses        businesses          @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products          products            @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  production_orders production_orders[]

  @@index([domain_data], map: "idx_boms_domain_data", type: Gin)
}

model bom_materials {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id String     @db.Uuid
  bom_id      String     @db.Uuid
  material_id String     @db.Uuid
  quantity    Decimal    @db.Decimal(12, 2)
  unit        String?
  boms        boms       @relation(fields: [bom_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  businesses  businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products    products   @relation(fields: [material_id], references: [id], onUpdate: NoAction)

  @@index([bom_id], map: "idx_bom_materials_bom")
}

model business_users {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id String     @db.Uuid
  user_id     String
  role        String     @default("salesperson")
  status      String?    @default("active")
  permissions Json?      @default("{}")
  invited_by  String?
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?  @default(now()) @db.Timestamptz(6)
  businesses  businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user        User       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([business_id, user_id], map: "unique_user_per_business")
}

model businesses {
  storefront_orders            storefront_orders[]
  storefront_order_items       storefront_order_items[]
  store_payment_settings       store_payment_settings?
  business_payment_methods     business_payment_methods[]
  stripe_connect_accounts      stripe_connect_accounts?
  storefront_analytics         storefront_analytics[]
  storefront_contact_messages storefront_contact_messages[]
  payment_transactions         payment_transactions[]
  business_settings            business_settings?
  feature_flags                feature_flags[]
  product_categories           product_categories[]
  notifications                notifications[]
  id                           String                         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id                      String?
  business_name                String
  email                        String
  phone                        String?
  ntn                          String?
  cnic                         String?
  srn                          String?
  address                      String?
  city                         String?
  state                        String?
  country                      String?                        @default("Pakistan")
  postal_code                  String?
  domain                       String                         @unique(map: "unique_business_domain")
  category                     String
  description                  String?
  logo_url                     String?
  cover_image_url              String?
  website                      String?
  is_active                    Boolean?                       @default(true)
  is_verified                  Boolean?                       @default(false)
  created_at                   DateTime?                      @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime?                      @default(now()) @db.Timestamptz(6)
  currency                     String?                        @default("PKR")
  timezone                     String?                        @default("Asia/Karachi")
  settings                     Json?                          @default("{}")
  fiscal_year_start            Int?                           @default(7)
  default_payment_terms        Int?                           @default(30)
  plan_tier                    String?                        @default("free") @db.VarChar(20)
  plan_expires_at              DateTime?                      @db.Timestamptz(6)
  plan_seats                   Int?                           @default(2)
  max_products                 Int?                           @default(100)
  max_warehouses               Int?                           @default(1)
  stripe_subscription_id       String?                        @db.VarChar(255)
  stripe_customer_id           String?                        @db.VarChar(255)
  stripe_subscription_status   String?                        @db.VarChar(32)
  approval_status              String                         @default("auto_approved") @db.VarChar(32)
  approval_requested_at        DateTime?                      @db.Timestamptz(6)
  approval_decided_at          DateTime?                      @db.Timestamptz(6)
  approval_decided_by          String?
  approval_notes               String?
  is_demo_requested            Boolean                        @default(false)
  demo_requested_at            DateTime?                      @db.Timestamptz(6)
  registration_requests        registration_requests[]
  subscription_history         subscription_history[]
  stripe_webhook_events        stripe_webhook_events[]
  bom_materials                bom_materials[]
  boms                         boms[]
  business_users               business_users[]
  user                         User?                          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  customers                    customers[]
  delivery_challans            delivery_challans[]
  gl_accounts                  gl_accounts[]
  gl_entries                   gl_entries[]
  journal_entries              journal_entries[]
  inventory_ledger             inventory_ledger[]
  invoice_items                invoice_items[]
  invoices                     invoices[]
  payments                     payments[]
  product_batches              product_batches[]
  product_serials              product_serials[]
  product_stock_locations      product_stock_locations[]
  product_variants             product_variants[]
  production_orders            production_orders[]
  products                     products[]
  purchases                    purchases[]
  quotation_items              quotation_items[]
  quotations                   quotations[]
  sales_order_items            sales_order_items[]
  sales_orders                 sales_orders[]
  stock_movements              stock_movements[]
  stock_transfers              stock_transfers[]
  tax_configurations           tax_configurations[]
  tax_payments                 tax_payments[]
  vendors                      vendors[]
  warehouse_locations          warehouse_locations[]
  workflow_rules               workflow_rules[]
  workflow_history             workflow_history[]
  audit_logs                   audit_logs[]
  promotions                   promotions[]
  promotion_products           promotion_products[]
  campaigns                    campaigns[]
  campaign_messages            campaign_messages[]
  customer_segments            customer_segments[]
  segment_customers            segment_customers[]
  inventory_reservations       inventory_reservations[]
  supplier_quotes              supplier_quotes[]
  price_lists                  price_lists[]
  price_list_items             price_list_items[]
  fiscal_periods               fiscal_periods[]
  expenses                     expenses[]
  exchange_rates               exchange_rates[]
  credit_notes                 credit_notes[]
  credit_note_items            credit_note_items[]
  pos_terminals                pos_terminals[]
  pos_sessions                 pos_sessions[]
  pos_transactions             pos_transactions[]
  pos_transaction_items        pos_transaction_items[]
  pos_payments                 pos_payments[]
  pos_refunds                  pos_refunds[]
  pos_refund_items             pos_refund_items[]
  loyalty_programs             loyalty_programs[]
  loyalty_transactions         loyalty_transactions[]
  restaurant_tables            restaurant_tables[]
  restaurant_orders            restaurant_orders[]
  restaurant_order_items       restaurant_order_items[]
  kitchen_orders               kitchen_orders[]
  approval_requests            approval_requests[]
  payroll_employees            payroll_employees[]
  payroll_runs                 payroll_runs[]
  payroll_items                payroll_items[]
  purchase_items               purchase_items[]
  challan_items                challan_items[]
  purchase_returns             purchase_returns[] // C16
  purchase_return_items        purchase_return_items[] // C16
  document_sequences           document_sequences[] // C17
  invoice_approvals            invoice_approvals[]
  invoice_templates            invoice_templates[]
  invoice_reminders            invoice_payment_reminders[]
  invoice_payments             invoice_payments[]
  reorder_points               reorder_points[]
  low_stock_alerts             low_stock_alerts[]
  inventory_abc_analysis       inventory_abc_analysis[]
  cycle_counts                 cycle_counts[]
  bank_reconciliation_sessions bank_reconciliation_sessions[]
  product_reviews              product_reviews[]
  membership_plans             membership_plans[]
  customer_memberships         customer_memberships[]
  membership_events            membership_events[]
  membership_benefits          membership_benefits[]

  @@index([approval_status, approval_requested_at(sort: Desc)], map: "idx_businesses_approval_status")
}

/// Registration approval audit trail (platform owner workflow).
model registration_requests {
  id                  String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id         String?    @db.Uuid
  user_id             String
  user_email          String
  user_name           String?
  business_name       String
  domain              String
  category            String
  country             String
  phone               String?
  plan_tier           String
  domain_package_key  String?
  requested_at        DateTime?  @default(now()) @db.Timestamptz(6)
  ip_address          String?
  user_agent          String?
  referrer            String?
  status              String     @default("pending") @db.VarChar(32)
  status_updated_at   DateTime?  @default(now()) @db.Timestamptz(6)
  decided_by          String?
  decided_at          DateTime?  @db.Timestamptz(6)
  decision_notes      String?
  demo_requested      Boolean    @default(false)
  demo_requested_at   DateTime?  @db.Timestamptz(6)
  demo_scheduled_at   DateTime?  @db.Timestamptz(6)
  demo_completed      Boolean    @default(false)
  internal_notes      String?
  tags                String[]
  created_at          DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?  @default(now()) @db.Timestamptz(6)
  businesses          businesses? @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([status, requested_at(sort: Desc)], map: "idx_registration_requests_status")
  @@index([user_id], map: "idx_registration_requests_user")
  @@index([business_id], map: "idx_registration_requests_business")
}

/// Append-only SaaS subscription / plan changes (not AR customer invoices).
model subscription_history {
  id                     String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id            String     @db.Uuid
  plan_tier              String?    @db.VarChar(50)
  status                 String?    @db.VarChar(50)
  stripe_subscription_id String?    @db.VarChar(255)
  effective_at           DateTime?  @default(now()) @db.Timestamptz(6)
  amount_minor           Int?
  currency               String?    @db.VarChar(10)
  metadata               Json?      @default("{}")
  created_at             DateTime?  @default(now()) @db.Timestamptz(6)
  businesses             businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([business_id, created_at(sort: Desc)], map: "idx_subscription_history_business_created")
}

/// Stripe webhook idempotency + audit trail (platform SaaS billing).
model stripe_webhook_events {
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  stripe_event_id String      @unique @db.VarChar(255)
  event_type      String      @db.VarChar(128)
  business_id     String?     @db.Uuid
  processed_at    DateTime    @default(now()) @db.Timestamptz(6)
  payload_digest  String?     @db.VarChar(128)
  metadata        Json?       @default("{}")
  businesses      businesses? @relation(fields: [business_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([event_type, processed_at], map: "idx_stripe_webhook_events_type_processed")
}

model customers {
  id                     String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id            String                   @db.Uuid
  name                   String
  email                  String?
  phone                  String?
  ntn                    String?
  cnic                   String?
  srn                    String?
  address                String?
  city                   String?
  state                  String?
  pincode                String?
  country                String?                  @default("Pakistan")
  credit_limit           Decimal?                 @default(0) @db.Decimal(12, 2)
  outstanding_balance    Decimal?                 @default(0) @db.Decimal(12, 2)
  created_at             DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at             DateTime?                @default(now()) @db.Timestamptz(6)
  domain_data            Json?                    @default("{}")
  opening_balance        Decimal?                 @default(0) @db.Decimal(12, 2)
  filer_status           String?                  @default("none") @db.VarChar(50)
  type                   String?                  @default("individual")
  notes                  String?
  is_active              Boolean                  @default(true)
  is_deleted             Boolean                  @default(false)
  deleted_at             DateTime?                @db.Timestamptz(6)
  businesses             businesses               @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  delivery_challans      delivery_challans[]
  invoices               invoices[]
  payments               payments[]
  product_serials        product_serials[]
  quotations             quotations[]
  sales_orders           sales_orders[]
  credit_notes           credit_notes[]
  pos_transactions       pos_transactions[]
  loyalty_transactions   loyalty_transactions[]
  restaurant_orders      restaurant_orders[]
  inventory_reservations inventory_reservations[]
  customer_memberships   customer_memberships[]

  @@index([domain_data], map: "idx_customers_domain_data", type: Gin)
  @@index([business_id, email])
  @@index([business_id, phone])
  @@index([is_deleted])
}

model gl_accounts {
  id                           String                         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id                  String                         @db.Uuid
  code                         String
  name                         String
  type                         String
  /// Optional sub-classification (e.g. current_asset) — used by accounting UI and actions.
  sub_type                     String?                        @db.VarChar(100)
  description                  String?
  parent_id                    String?                        @db.Uuid
  is_active                    Boolean?                       @default(true)
  created_at                   DateTime?                      @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime?                      @default(now()) @updatedAt @db.Timestamptz(6)
  is_system                    Boolean?                       @default(false)
  businesses                   businesses                     @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  gl_accounts                  gl_accounts?                   @relation("gl_accountsTogl_accounts", fields: [parent_id], references: [id], onUpdate: NoAction)
  other_gl_accounts            gl_accounts[]                  @relation("gl_accountsTogl_accounts")
  gl_entries                   gl_entries[]
  expenses                     expenses[]
  bank_reconciliation_sessions bank_reconciliation_sessions[]

  @@unique([business_id, code])
}

model gl_entries {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id      String           @db.Uuid
  journal_id       String?          @db.Uuid
  transaction_date DateTime         @db.Date
  description      String?
  account_id       String           @db.Uuid
  debit            Decimal?         @default(0) @db.Decimal(12, 2)
  credit           Decimal?         @default(0) @db.Decimal(12, 2)
  reference_type   String?
  reference_id     String?          @db.Uuid
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  gl_accounts      gl_accounts      @relation(fields: [account_id], references: [id], onUpdate: NoAction)
  businesses       businesses       @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  journal_entries  journal_entries? @relation(fields: [journal_id], references: [id], onUpdate: NoAction)

  bank_statement_lines bank_statement_lines[]

  @@index([journal_id])
  @@index([business_id, account_id, transaction_date(sort: Desc)], name: "idx_gl_entries_business_account_date")
  @@index([business_id, reference_type, reference_id], name: "idx_gl_entries_business_ref_type_id")
  @@index([business_id, journal_id], name: "idx_gl_entries_business_journal")
}

model invoices {
  invoice_payments invoice_payments[]
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id      String             @db.Uuid
  invoice_number   String
  customer_id      String?            @db.Uuid
  created_by       String?
  date             DateTime           @db.Date
  due_date         DateTime?          @db.Date
  subtotal         Decimal?           @default(0.00) @db.Decimal(12, 2)
  total_tax        Decimal?           @default(0.00) @db.Decimal(12, 2)
  total_amount     Decimal?           @default(0.00) @db.Decimal(12, 2)
  status           String?            @default("draft") // draft, sent, viewed, approved, payment_pending, partially_paid, paid, overdue, voided, amended
  notes            String?
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @default(now()) @db.Timestamptz(6)
  tax_total        Decimal?           @default(0) @db.Decimal(12, 2)
  discount_total   Decimal?           @default(0) @db.Decimal(12, 2)
  grand_total      Decimal?           @default(0) @db.Decimal(12, 2)
  payment_method   String?
  payment_status   String?
  terms            String?
  tax_details      Json?              @default("{}")
  is_deleted       Boolean            @default(false)
  deleted_at       DateTime?          @db.Timestamptz(6)

  // Workflow & Approval Fields
  approval_status     String?   @default("none") // none, pending, approved, rejected
  approval_by         String?
  approval_date       DateTime? @db.Timestamptz(6)
  approval_notes      String?
  sent_by             String?
  sent_date           DateTime? @db.Timestamptz(6)
  viewed_date         DateTime? @db.Timestamptz(6)
  print_count         Int?      @default(0)
  email_sent_count    Int?      @default(0)
  fbr_status          String?   @default("pending") // pending, valid, invalid, sync_error
  fbr_response        Json?     @default("{}")
  template_id         String?   @db.Uuid
  is_recurring        Boolean?  @default(false)
  recurring_parent_id String?   @db.Uuid
  recurring_frequency String? // daily, weekly, monthly, quarterly, yearly
  next_invoice_date   DateTime? @db.Date

  // Relations
  invoice_items       invoice_items[]
  payment_allocations payment_allocations[]
  credit_notes        credit_notes[]
  pos_transactions    pos_transactions[]
  invoice_approvals   invoice_approvals[]
  invoice_reminders   invoice_payment_reminders[]
  recurring_invoices  invoices[]                  @relation("RecurringInvoices")
  parent_invoice      invoices?                   @relation("RecurringInvoices", fields: [recurring_parent_id], references: [id], onDelete: SetNull)
  membership_initial  customer_memberships[]      @relation("MembershipInitialInvoice")
  membership_recurring customer_memberships[]     @relation("MembershipRecurringInvoice")

  businesses businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  customers  customers? @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator    User?      @relation("invoices_created_by", fields: [created_by], references: [id], onDelete: SetNull)

  /// Active-row uniqueness: partial unique index invoices_business_invoice_number_active_key (WHERE is_deleted = false)
  @@index([business_id, invoice_number])
  @@index([business_id, date])
  @@index([business_id, status])
  @@index([is_deleted])
  @@index([business_id, status, date(sort: Desc)], name: "idx_invoices_business_status_date")
  @@index([business_id, customer_id, payment_status], name: "idx_invoices_business_customer_payment")
  @@index([business_id, is_deleted, date(sort: Desc)], name: "idx_invoices_business_deleted_date")
  @@index([business_id, approval_status])
  @@index([business_id, fbr_status])
  @@index([is_recurring])
}

model invoice_approvals {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id     String   @db.Uuid
  invoice_id      String   @db.Uuid
  approved_by     String?
  approval_status String // approved, rejected
  notes           String?
  metadata        Json?    @default("{}")
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  businesses businesses @relation(fields: [business_id], references: [id], onDelete: Cascade)
  invoices   invoices   @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  approver   User?      @relation("invoice_approvals", fields: [approved_by], references: [id], onDelete: SetNull)

  @@unique([invoice_id, approved_by])
  @@index([business_id])
  @@index([approved_by])
  @@index([created_at(sort: Desc)])
}

model invoice_templates {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id   String   @db.Uuid
  name          String
  description   String?
  template_type String // standard, recurring, credit_note
  items         Json     @default("[]") // Template items
  notes         String?
  terms         String?
  tax_category  String?
  is_active     Boolean  @default(true)
  metadata      Json?    @default("{}")
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @db.Timestamptz(6)
  created_by    String?

  businesses businesses @relation(fields: [business_id], references: [id], onDelete: Cascade)
  creator    User?      @relation("invoice_templates", fields: [created_by], references: [id], onDelete: SetNull)

  @@unique([business_id, name])
  @@index([business_id])
  @@index([is_active])
  @@index([template_type])
}

model invoice_payment_reminders {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id    String    @db.Uuid
  invoice_id     String    @db.Uuid
  reminder_type  String // first_due, overdue_3days, overdue_7days, overdue_14days, overdue_30days
  scheduled_date DateTime  @db.Date
  sent_date      DateTime? @db.Timestamptz(6)
  is_sent        Boolean   @default(false)
  metadata       Json?     @default("{}")
  created_at     DateTime  @default(now()) @db.Timestamptz(6)

