// ═══════════════════════════════════════════════════════════════════════

model pos_terminals {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id     String               @db.Uuid
  name            String               @db.VarChar(100)
  code            String?              @db.VarChar(20)
  warehouse_id    String?              @db.Uuid
  status          String               @default("active") @db.VarChar(20)
  hardware_config Json?                @default("{}")
  created_at      DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?            @default(now()) @db.Timestamptz(6)
  businesses      businesses           @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  warehouse       warehouse_locations? @relation(fields: [warehouse_id], references: [id], onUpdate: NoAction)
  pos_sessions    pos_sessions[]

  @@unique([business_id, code])
  @@index([business_id])
}

model pos_sessions {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String             @db.Uuid
  terminal_id      String             @db.Uuid
  user_id          String
  opening_balance  Decimal            @default(0) @db.Decimal(12, 2)
  closing_balance  Decimal?           @db.Decimal(12, 2)
  expected_balance Decimal?           @db.Decimal(12, 2)
  difference       Decimal?           @db.Decimal(12, 2)
  status           String             @default("open") @db.VarChar(20)
  opened_at        DateTime?          @default(now()) @db.Timestamptz(6)
  closed_at        DateTime?          @db.Timestamptz(6)
  notes            String?
  businesses       businesses         @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pos_terminals    pos_terminals      @relation(fields: [terminal_id], references: [id], onUpdate: NoAction)
  user             User               @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  pos_transactions pos_transactions[]

  @@index([business_id])
  @@index([terminal_id])
  @@index([status])
}

model pos_transactions {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id           String                  @db.Uuid
  session_id            String                  @db.Uuid
  transaction_number    String                  @db.VarChar(50)
  customer_id           String?                 @db.Uuid
  invoice_id            String?                 @db.Uuid // C18: Link to formal invoice if converted
  subtotal              Decimal                 @db.Decimal(12, 2)
  tax_amount            Decimal?                @default(0) @db.Decimal(12, 2)
  discount_amount       Decimal?                @default(0) @db.Decimal(12, 2)
  total_amount          Decimal                 @db.Decimal(12, 2)
  payment_status        String                  @default("completed") @db.VarChar(20)
  transaction_type      String                  @default("sale") @db.VarChar(20)
  is_voided             Boolean                 @default(false)
  voided_by             String?
  voided_at             DateTime?               @db.Timestamptz(6)
  void_reason           String?
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  businesses            businesses              @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pos_sessions          pos_sessions            @relation(fields: [session_id], references: [id], onUpdate: NoAction)
  customers             customers?              @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  invoices              invoices?               @relation(fields: [invoice_id], references: [id], onUpdate: NoAction)
  pos_transaction_items pos_transaction_items[]
  pos_payments          pos_payments[]
  pos_refunds           pos_refunds[]

  @@unique([business_id, transaction_number])
  @@index([business_id])
  @@index([session_id])
  @@index([invoice_id])
  @@index([business_id, created_at(sort: Desc)])
}

model pos_transaction_items {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String?          @db.Uuid
  transaction_id   String           @db.Uuid
  product_id       String           @db.Uuid
  variant_id       String?          @db.Uuid
  batch_id         String?          @db.Uuid
  serial_number    String?          @db.VarChar(255)
  quantity         Decimal          @db.Decimal(12, 2)
  unit_price       Decimal          @db.Decimal(12, 2)
  discount_amount  Decimal?         @default(0) @db.Decimal(12, 2)
  tax_amount       Decimal?         @default(0) @db.Decimal(12, 2)
  total_amount     Decimal          @db.Decimal(12, 2)
  promotion_id     String?          @db.Uuid
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  businesses       businesses?      @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pos_transactions pos_transactions @relation(fields: [transaction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products         products         @relation(fields: [product_id], references: [id], onUpdate: NoAction)

  @@index([business_id], map: "idx_pos_tx_items_business_id")
  @@index([transaction_id])
  @@index([product_id])
}

model pos_payments {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String?          @db.Uuid
  transaction_id   String           @db.Uuid
  method           String           @db.VarChar(50)
  amount           Decimal          @db.Decimal(12, 2)
  reference        String?          @db.VarChar(255)
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  businesses       businesses?      @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pos_transactions pos_transactions @relation(fields: [transaction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([business_id], map: "idx_pos_payments_business_id")
  @@index([transaction_id])
}

// ─── Phase 3: POS Enhancement ───────────────────────────────────────────────

model pos_refunds {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String             @db.Uuid
  transaction_id   String             @db.Uuid
  refund_number    String             @db.VarChar(50)
  refund_type      String             @default("full") @db.VarChar(20) // full | partial | exchange
  reason           String?
  subtotal         Decimal            @db.Decimal(12, 2)
  tax_amount       Decimal?           @default(0) @db.Decimal(12, 2)
  total_amount     Decimal            @db.Decimal(12, 2)
  refund_method    String             @default("cash") @db.VarChar(20) // cash | card | store_credit
  status           String             @default("completed") @db.VarChar(20)
  processed_by     String?
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  businesses       businesses         @relation(fields: [business_id], references: [id], onDelete: Cascade)
  pos_transactions pos_transactions   @relation(fields: [transaction_id], references: [id])
  pos_refund_items pos_refund_items[]

  @@unique([business_id, refund_number])
  @@index([business_id])
  @@index([transaction_id])
}

model pos_refund_items {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id   String?     @db.Uuid
  refund_id     String      @db.Uuid
  product_id    String?     @db.Uuid
  product_name  String
  quantity      Decimal     @db.Decimal(12, 2)
  unit_price    Decimal     @db.Decimal(12, 2)
  refund_amount Decimal     @db.Decimal(12, 2)
  restock       Boolean     @default(true)
  created_at    DateTime?   @default(now()) @db.Timestamptz(6)
  businesses    businesses? @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pos_refunds   pos_refunds @relation(fields: [refund_id], references: [id], onDelete: Cascade)

  @@index([business_id], map: "idx_pos_refund_items_business_id")
  @@index([refund_id])
}

model loyalty_programs {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id          String                 @db.Uuid
  name                 String                 @db.VarChar(100)
  points_per_amount    Decimal                @default(1) @db.Decimal(8, 2) // points earned per currency unit spent
  currency_per_point   Decimal                @default(1) @db.Decimal(8, 2) // currency value per point redeemed
  min_redeem_points    Int                    @default(100)
  is_active            Boolean                @default(true)
  created_at           DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?              @default(now()) @db.Timestamptz(6)
  businesses           businesses             @relation(fields: [business_id], references: [id], onDelete: Cascade)
  loyalty_transactions loyalty_transactions[]

  @@index([business_id])
}

model loyalty_transactions {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String           @db.Uuid
  program_id       String           @db.Uuid
  customer_id      String           @db.Uuid
  type             String           @db.VarChar(20) // earn | redeem | adjust | expire
  points           Int
  reference_type   String?          @db.VarChar(50) // pos_transaction | manual
  reference_id     String?          @db.Uuid
  balance_after    Int              @default(0)
  description      String?
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  businesses       businesses       @relation(fields: [business_id], references: [id], onDelete: Cascade)
  loyalty_programs loyalty_programs @relation(fields: [program_id], references: [id])
  customers        customers        @relation(fields: [customer_id], references: [id])

  @@index([business_id])
  @@index([customer_id])
  @@index([program_id])
}

// ─── Phase 5: Restaurant Vertical ───────────────────────────────────────────

model restaurant_tables {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id       String              @db.Uuid
  table_number      String              @db.VarChar(20)
  section           String?             @db.VarChar(50) // indoor | outdoor | terrace | vip
  capacity          Int                 @default(4)
  status            String              @default("available") @db.VarChar(20) // available | occupied | reserved | maintenance
  current_order_id  String?             @db.Uuid
  is_active         Boolean             @default(true)
  sort_order        Int                 @default(0)
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  businesses        businesses          @relation(fields: [business_id], references: [id], onDelete: Cascade)
  restaurant_orders restaurant_orders[]

  @@unique([business_id, table_number])
  @@index([business_id])
}

model restaurant_orders {
  payment_method String?
  payment_status String?
  tip_amount     Decimal? @db.Decimal(12, 2)
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id            String                   @db.Uuid
  order_number           String                   @db.VarChar(50)
  table_id               String?                  @db.Uuid
  order_type             String                   @default("dine_in") @db.VarChar(20) // dine_in | takeaway | delivery
  customer_id            String?                  @db.Uuid
  waiter_id              String?
  status                 String                   @default("pending") @db.VarChar(20) // pending | preparing | ready | served | completed | cancelled
  subtotal               Decimal?                 @default(0) @db.Decimal(12, 2)
  tax_amount             Decimal?                 @default(0) @db.Decimal(12, 2)
  discount_amount        Decimal?                 @default(0) @db.Decimal(12, 2)
  total_amount           Decimal?                 @default(0) @db.Decimal(12, 2)
  notes                  String?
  created_at             DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at             DateTime?                @default(now()) @db.Timestamptz(6)
  businesses             businesses               @relation(fields: [business_id], references: [id], onDelete: Cascade)
  restaurant_tables      restaurant_tables?       @relation(fields: [table_id], references: [id])
  customers              customers?               @relation(fields: [customer_id], references: [id])
  restaurant_order_items restaurant_order_items[]
  kitchen_orders         kitchen_orders[]

  @@unique([business_id, order_number])
  @@index([business_id])
  @@index([table_id])
  @@index([status])
}

model restaurant_order_items {
  id                   String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id          String?           @db.Uuid
  order_id             String            @db.Uuid
  product_id           String?           @db.Uuid
  item_name            String
  quantity             Int               @default(1)
  unit_price           Decimal           @db.Decimal(12, 2)
  modifiers            Json?             @default("[]") // [{name, price}]
  special_instructions String?
  status               String            @default("pending") @db.VarChar(20) // pending | sent_to_kitchen | preparing | ready | served | cancelled
  created_at           DateTime?         @default(now()) @db.Timestamptz(6)
  businesses           businesses?       @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  restaurant_orders    restaurant_orders @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([business_id], map: "idx_restaurant_order_items_business_id")
  @@index([order_id])
}

model kitchen_orders {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id       String            @db.Uuid
  order_id          String            @db.Uuid
  station           String?           @db.VarChar(50) // grill | fryer | salad | bar | dessert
  priority          Int               @default(0) // 0=normal, 1=rush
  status            String            @default("pending") @db.VarChar(20) // pending | preparing | ready | completed
  items             Json              @default("[]") // [{item_name, qty, mods, special}]
  estimated_time    Int? // minutes
  started_at        DateTime?         @db.Timestamptz(6)
  completed_at      DateTime?         @db.Timestamptz(6)
  created_at        DateTime?         @default(now()) @db.Timestamptz(6)
  businesses        businesses        @relation(fields: [business_id], references: [id], onDelete: Cascade)
  restaurant_orders restaurant_orders @relation(fields: [order_id], references: [id])

  @@index([business_id])
  @@index([order_id])
  @@index([status])
}

// ─── Phase 6: Differentiation ───────────────────────────────────────────────

model approval_requests {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String     @db.Uuid
  request_type     String     @db.VarChar(50) // expense | purchase | refund | credit_note | journal_entry
  reference_id     String?    @db.Uuid
  requested_by     String
  approver_id      String?
  status           String     @default("pending") @db.VarChar(20) // pending | approved | rejected | cancelled
  priority         String     @default("medium") @db.VarChar(20) // low | medium | high | critical
  title            String?    @db.VarChar(255)
  amount           Decimal?   @db.Decimal(12, 2)
  description      String?
  rejection_reason String?
  metadata         Json?      @default("{}")
  requested_at     DateTime?  @default(now()) @db.Timestamptz(6)
  resolved_at      DateTime?  @db.Timestamptz(6)
  businesses       businesses @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@index([business_id])
  @@index([approver_id])
  @@index([status])
}


model payroll_employees {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id   String          @db.Uuid
  user_id       String?
  employee_code String          @db.VarChar(50)
  full_name     String
  cnic          String?         @db.VarChar(15)
  phone         String?         @db.VarChar(20)
  email         String?         @db.VarChar(100)
  department    String?         @db.VarChar(100)
  designation   String?         @db.VarChar(100)
  join_date     DateTime?       @db.Date
  base_salary   Decimal         @default(0) @db.Decimal(12, 2)
  bank_name     String?         @db.VarChar(100)
  bank_account  String?         @db.VarChar(50)
  tax_filer     Boolean         @default(false)
  status        String          @default("active") @db.VarChar(20) // active | inactive | terminated
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?       @default(now()) @db.Timestamptz(6)
  businesses    businesses      @relation(fields: [business_id], references: [id], onDelete: Cascade)
  payroll_items payroll_items[]

  @@unique([business_id, employee_code])
  @@index([business_id])
}

model payroll_runs {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String          @db.Uuid
  run_number       String          @db.VarChar(50)
  period_month     Int // 1-12
  period_year      Int
  total_gross      Decimal         @default(0) @db.Decimal(12, 2)
  total_deductions Decimal         @default(0) @db.Decimal(12, 2)
  total_net        Decimal         @default(0) @db.Decimal(12, 2)
  employee_count   Int             @default(0)
  status           String          @default("draft") @db.VarChar(20) // draft | processing | completed | paid
  processed_by     String?
  processed_at     DateTime?       @db.Timestamptz(6)
  created_at       DateTime?       @default(now()) @db.Timestamptz(6)
  businesses       businesses      @relation(fields: [business_id], references: [id], onDelete: Cascade)
  payroll_items    payroll_items[]

  @@unique([business_id, run_number])
  @@unique([business_id, period_month, period_year])
  @@index([business_id])
}

model payroll_items {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id       String?           @db.Uuid
  run_id            String            @db.Uuid
  employee_id       String            @db.Uuid
  base_salary       Decimal           @db.Decimal(12, 2)
  allowances        Decimal           @default(0) @db.Decimal(12, 2)
  overtime          Decimal           @default(0) @db.Decimal(12, 2)
  gross_salary      Decimal           @db.Decimal(12, 2)
  tax_deduction     Decimal           @default(0) @db.Decimal(12, 2)
  eobi              Decimal           @default(0) @db.Decimal(12, 2) // Pakistan EOBI
  loan_deduction    Decimal           @default(0) @db.Decimal(12, 2)
  other_deductions  Decimal           @default(0) @db.Decimal(12, 2)
  total_deductions  Decimal           @default(0) @db.Decimal(12, 2)
  net_salary        Decimal           @db.Decimal(12, 2)
  payment_status    String            @default("pending") @db.VarChar(20) // pending | paid
  payment_method    String?           @db.VarChar(20) // cash | bank_transfer
  created_at        DateTime?         @default(now()) @db.Timestamptz(6)
  businesses        businesses?       @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payroll_runs      payroll_runs      @relation(fields: [run_id], references: [id], onDelete: Cascade)
  payroll_employees payroll_employees @relation(fields: [employee_id], references: [id])

  @@index([business_id], map: "idx_payroll_items_business_id")
  @@index([run_id])
  @@index([employee_id])
}

// ============================================================================
// PURCHASE RETURNS MODULE (C16)
// ============================================================================

model purchase_returns {
  id                  String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id         String                   @db.Uuid
  vendor_id           String                   @db.Uuid
  return_number       String                   @db.VarChar(50)
  return_date         DateTime                 @default(now()) @db.Date
  original_purchase_id String?                 @db.Uuid
  subtotal            Decimal                  @db.Decimal(12, 2)
  tax_amount          Decimal                  @default(0) @db.Decimal(12, 2)
  total_amount        Decimal                  @db.Decimal(12, 2)
  status              String                   @default("pending") @db.VarChar(20) // pending | approved | completed
  reason              String?
  notes               String?
  created_at          DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at          DateTime                 @default(now()) @db.Timestamptz(6)
  created_by          String?                  @db.Uuid
  
  businesses          businesses               @relation(fields: [business_id], references: [id], onDelete: Cascade)
  vendors             vendors                  @relation(fields: [vendor_id], references: [id])
  purchase_return_items purchase_return_items[]
  
  @@unique([business_id, return_number])
  @@index([business_id])
  @@index([vendor_id])
  @@index([business_id, return_date(sort: Desc)])
}

model purchase_return_items {
  id                String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id       String           @db.Uuid
  return_id         String           @db.Uuid
  product_id        String           @db.Uuid
  quantity          Decimal          @db.Decimal(12, 2)
  unit_price        Decimal          @db.Decimal(12, 2)
  tax_amount        Decimal          @default(0) @db.Decimal(12, 2)
  total             Decimal          @db.Decimal(12, 2)
  batch_number      String?
  notes             String?
  created_at        DateTime         @default(now()) @db.Timestamptz(6)
  
  businesses        businesses       @relation(fields: [business_id], references: [id], onDelete: Cascade)
  purchase_returns  purchase_returns @relation(fields: [return_id], references: [id], onDelete: Cascade)
  products          products         @relation(fields: [product_id], references: [id])
  
  @@index([business_id])
  @@index([return_id])
  @@index([product_id])
}

// ============================================================================
// DOCUMENT SEQUENCES MODULE (C17)
// ============================================================================

model document_sequences {
  id              String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id     String     @db.Uuid
  document_type   String     @db.VarChar(50) // invoice | purchase | pos_transaction | etc.
  prefix          String     @default("") @db.VarChar(20)
  current_number  Int        @default(1)
  padding_length  Int        @default(6) // e.g., 6 = 000001
  suffix          String?    @db.VarChar(20)
  reset_frequency String?    @db.VarChar(20) // null | yearly | monthly
  last_reset_date DateTime?  @db.Date
  reset_by        String?    @db.VarChar(255)
  reset_reason    String?
  reset_at        DateTime?  @db.Timestamptz(6)
  created_at      DateTime   @default(now()) @db.Timestamptz(6)
  updated_at      DateTime   @default(now()) @db.Timestamptz(6)
  
  businesses      businesses @relation(fields: [business_id], references: [id], onDelete: Cascade)
  
  @@unique([business_id, document_type])
  @@index([business_id])
}

model storefront_orders {
  id                 Int                      @id @default(autoincrement())
  business_id        String                   @db.Uuid
  order_number       String                   @unique
  customer_email     String?
  customer_phone     String?
  customer_name      String?
  shipping_address   String?
  billing_address    String?
  subtotal           Decimal?                 @default(0) @db.Decimal(12, 2)
  tax_amount         Decimal?                 @default(0) @db.Decimal(12, 2)
  shipping_amount    Decimal?                 @default(0) @db.Decimal(12, 2)
  discount_amount    Decimal?                 @default(0) @db.Decimal(12, 2)
  total_amount       Decimal?                 @default(0) @db.Decimal(12, 2)
  currency           String?                  @default("PKR")
  status             String?                  @default("pending")
  payment_status     String?                  @default("pending")
  fulfillment_status String?                  @default("unfulfilled")
  notes              String?
  metadata           Json?
  created_at         DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?                @default(now()) @db.Timestamptz(6)
  businesses         businesses               @relation(fields: [business_id], references: [id], onDelete: Cascade)
  items              storefront_order_items[]
}

model storefront_order_items {
  id           Int                @id @default(autoincrement())
  order_id     Int
  product_id   String?            @db.Uuid
  product_name String?
  quantity     Decimal            @default(1) @db.Decimal(12, 2)
  unit_price   Decimal            @default(0) @db.Decimal(12, 2)
  tax_amount   Decimal?           @default(0) @db.Decimal(12, 2)
  total_price  Decimal?           @default(0) @db.Decimal(12, 2)
  metadata     Json?
  order        storefront_orders  @relation(fields: [order_id], references: [id], onDelete: Cascade)
}

model store_payment_settings {
  id                      String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  business_id             String     @unique @db.Uuid
  allow_cod               Boolean?   @default(true)
  allow_prepaid           Boolean?   @default(true)
  require_cvv             Boolean?   @default(true)
  require_billing_address Boolean?   @default(false)
  allow_save_cards        Boolean?   @default(false)
  auto_capture_payments   Boolean?   @default(true)
  default_currency        String?    @default("PKR")
  cod_instructions        String?
  payment_instructions    String?
  enable_easypaisa        Boolean?   @default(false)
  enable_jazzcash         Boolean?   @default(false)
