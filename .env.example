# TENVO — example environment (copy to `.env` and/or `.env.local`, then fill values).
# Next.js load order: `.env` → `.env.local` → `.env.development.local` (later wins).
# Production: set NEXT_PUBLIC_DEV_FULL_FEATURES=false, real STRIPE_* / RESEND / DB, and BETTER_AUTH_SECRET (32+ chars).

# ═══════════════════════════════════════════════════════════════
# FEATURE FLAGS (local QA defaults)
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_DEV_FULL_FEATURES=true
NEXT_PUBLIC_USE_ENHANCED_SWITCHER=true
NEXT_PUBLIC_ENABLE_UNIFIED_DASHBOARD=true
NEXT_PUBLIC_ENABLE_ROLE_TEMPLATES=true
NEXT_PUBLIC_ENABLE_LAYOUT_PERSISTENCE=true
NEXT_PUBLIC_ENABLE_REALTIME_UPDATES=true
NEXT_PUBLIC_ENABLE_SMART_DEFAULTS=true

# ═══════════════════════════════════════════════════════════════
# CORE APP
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
# Optional alias for some scripts (falls back to DATABASE_URL)
# POSTGRES_URL=

# TLS for `pg` / Prisma (see lib/db.js)
# DATABASE_SSL_STRICT=true
# DATABASE_SSL_CA_PATH=/path/to/ca.pem
# DATABASE_SSL_DISABLE=true
# DATABASE_SSL_INSECURE=true

# Production canonical: https://www.tenvo.store (required for NOWPayments IPN + crypto success URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NOWPAYMENTS_IPN_CALLBACK_URL=https://www.tenvo.store/api/webhooks/nowpayments
NEXT_PUBLIC_SUPPORT_EMAIL=support@tenvo.com

# SEO & analytics (production — www.tenvo.store)
# BETTER_AUTH_URL=https://www.tenvo.store
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-token
# NEXT_PUBLIC_BING_SITE_VERIFICATION=your-bing-verification-token
# NEXT_PUBLIC_TWITTER_HANDLE=tenvo
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/company/tenvo

# Platform sales scheduling (Calendly). Used by pricing, demo, and enterprise CTAs.
# NEXT_PUBLIC_SALES_MEETING_URL=https://calendly.com/zeeshan-mindscape/30min
# Legacy aliases also supported: NEXT_PUBLIC_MEETING_URL, SALES_MEETING_URL, MEETING_URL, meeting_url

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Playwright / E2E (optional)
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# ═══════════════════════════════════════════════════════════════
# BETTER AUTH (sessions, email/password, OTP plugin, OAuth)
# ═══════════════════════════════════════════════════════════════
# Required in production (32+ random chars)
BETTER_AUTH_SECRET=

# Server canonical URL for OAuth redirect_uri and emailed links (no trailing slash).
# Prefer this in production; falls back to NEXT_PUBLIC_APP_URL then NEXT_PUBLIC_BETTER_AUTH_URL.
BETTER_AUTH_URL=http://localhost:3000

# Optional: comma-separated host:port list so OAuth redirect_uri matches the request host
# (e.g. localhost:3000,127.0.0.1:3000). Add each origin’s callback in Google Cloud Console:
#   https://<host>/api/auth/callback/google
# BETTER_AUTH_ALLOWED_HOSTS=localhost:3000,127.0.0.1:3000

# Browser auth client base (must reach /api/auth/* on this host)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (server) — Web application client in Google Cloud Console.
# Authorized JavaScript origins (add apex + www if both are reachable):
#   https://www.tenvo.store
#   https://tenvo.store
# Authorized redirect URI (single canonical — must match BETTER_AUTH_URL):
#   https://www.tenvo.store/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional extra origins for Better Auth callbackURL checks (comma-separated origins or hosts)
# BETTER_AUTH_TRUSTED_ORIGINS=https://preview.tenvo.store

# Auto-derived www + apex trusted origins when BETTER_AUTH_URL / NEXT_PUBLIC_APP_URL are set.
# Optional explicit host list for dynamic redirect_uri (local dev):
# BETTER_AUTH_ALLOWED_HOSTS=localhost:3000,127.0.0.1:3000

# Show “Continue with Google” on /login when true AND server keys above are set
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# ═══════════════════════════════════════════════════════════════
# PLATFORM / BILLING
# ═══════════════════════════════════════════════════════════════
# Initial launch / UAT: `manual` applies plans instantly only when STRIPE_SECRET_KEY is unset.
# With Stripe keys set, card checkout works even in manual mode; offline payment always works.
# Production card SaaS: `stripe` (or omit BILLING_MODE) + STRIPE_* + webhook. No STRIPE_PRICE_* required.
BILLING_MODE=manual
PLATFORM_OWNER_EMAILS=you@example.com
# Registration approval alerts (optional). Use a dedicated admin inbox so your tenant
# login is not flooded when it also appears in PLATFORM_OWNER_EMAILS.
# REGISTRATION_APPROVAL_NOTIFY_EMAILS=admin@yourcompany.com
# PLATFORM_OWNER_EMAIL_EXTRA=
# PLATFORM_OWNER_EMAIL=
# Demo data lab (bun run data-lab:seed) — defaults to first PLATFORM_OWNER_EMAILS entry:
# DEMO_SEED_OWNER_EMAIL=you@example.com

# ═══════════════════════════════════════════════════════════════
# RESEND (transactional email — OTP, marketing forms, product mail)
# Required for registration OTP in production: both key AND verified sender domain.
# Also used as platform-default sender for hub outreach when a tenant has no custom Resend key
# (Hub → Campaigns → Integrations → “Platform default”).
RESEND_API_KEY=
RESEND_FROM=TENVO <hello@your-verified-domain.com>

MARKETING_INBOUND_EMAIL=tenvo@example.com
# CONTACT_INBOUND_EMAIL=

# ═══════════════════════════════════════════════════════════════
# CAMPAIGNS HUB (outreach, segments, scheduled dispatch)
# Per-tenant overrides (custom Resend, Twilio, WhatsApp webhook, AI endpoint) live in
# businesses.settings.campaigns.integrations — configured in Hub → Campaigns → Integrations.
# Platform env vars below are fallbacks when the tenant uses “platform default”.
# ═══════════════════════════════════════════════════════════════
# Scheduled outreach: queue + email dispatch for campaigns with scheduled_at in the past.
# POST /api/internal/campaigns/dispatch-scheduled
# Auth: Authorization: Bearer <secret>  OR  x-cron-secret: <secret>
# Vercel Cron example path: /api/internal/campaigns/dispatch-scheduled (daily or hourly)
CRON_SECRET=
# INTERNAL_CRON_SECRET=

# Tenant membership renewals + expiry (gym, spa, salon, etc.)
# POST /api/internal/memberships/process-renewals
# Auth: Authorization: Bearer <CRON_SECRET>
# Schedule daily (e.g. Vercel Cron): /api/internal/memberships/process-renewals

# ═══════════════════════════════════════════════════════════════
# STRIPE (SaaS + Connect + storefront — lib/payments/stripe.js)
# ═══════════════════════════════════════════════════════════════
# SaaS subscription amounts come from code (`lib/config/plans.js`, `lib/config/domainPackages.js`)
# via `lib/payments/stripeCatalog.js` — Checkout uses inline price_data; no dashboard Price IDs required.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional: enable Stripe Tax on Checkout when your Stripe account has Tax configured
# STRIPE_AUTOMATIC_TAX=true

# Optional: offline payment account details shown to owners in Settings → Billing
# TENVO_MANUAL_PAYMENT_JAZZCASH=03XX-XXXXXXX
# TENVO_MANUAL_PAYMENT_EASYPAISA=03XX-XXXXXXX
# TENVO_MANUAL_PAYMENT_BANK=Bank name · Account title · IBAN
# TENVO_BILLING_SUPPORT_EMAIL=billing@yourdomain.com
# Also used as fallback in billing copy when TENVO_BILLING_SUPPORT_EMAIL is unset:
# SUPPORT_EMAIL=support@yourdomain.com
# Optional legacy fallback only (deprecated — leave blank for dynamic catalog billing):
STRIPE_PRICE_STARTER_MONTHLY_PKR=
# Legacy mid-tier alias → professional in app; prefer STRIPE_PRICE_PROFESSIONAL_* when possible
STRIPE_PRICE_GROWTH_MONTHLY_PKR=
STRIPE_PRICE_PROFESSIONAL_MONTHLY_PKR=
STRIPE_PRICE_BUSINESS_MONTHLY_PKR=
STRIPE_PRICE_STARTER_MONTHLY_USD=
STRIPE_PRICE_GROWTH_MONTHLY_USD=
STRIPE_PRICE_PROFESSIONAL_MONTHLY_USD=
STRIPE_PRICE_BUSINESS_MONTHLY_USD=

# ═══════════════════════════════════════════════════════════════
# NOWPayments (crypto invoices — lib/payments/nowpayments.js)
# IPN signing secret (dashboard → IPN). Same value accepted as NOWPAYMENTS_IPN_SECRET or NOWPAYMENTS_SECRET.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
# NOWPAYMENTS_SECRET=
# NOWPAYMENTS_IPN_CALLBACK_URL=

# ═══════════════════════════════════════════════════════════════
# SUPABASE (storage upload route, legacy auth callback, anon client)
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=

# ═══════════════════════════════════════════════════════════════
# AI — product / marketing (see app/api/marketing/assistant/route.js)
# ═══════════════════════════════════════════════════════════════
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_GENERATIVE_AI_MODEL=gemini-flash-lite-latest
# GOOGLE_GENERATIVE_AI_SERVICE_TIER=flex

# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# MARKETING_ASSISTANT_PRIMARY=gemini

# OPENAI_API_KEY=

# ═══════════════════════════════════════════════════════════════
# PRODUCTION LAUNCH CHECKLIST (MVP)
# ═══════════════════════════════════════════════════════════════
# Before first market launch, set at minimum:
#   NEXT_PUBLIC_DEV_FULL_FEATURES=false
#   BETTER_AUTH_SECRET=<32+ random chars>
#   BETTER_AUTH_URL=https://your-domain.com  (no trailing slash)
#   NEXT_PUBLIC_APP_URL=https://your-domain.com
#   RESEND_API_KEY + RESEND_FROM on a verified sending domain (required for OTP + default outreach)
#   CRON_SECRET (or INTERNAL_CRON_SECRET) if using scheduled outreach campaigns
#   DATABASE_URL (+ DIRECT_URL for Prisma migrations)
#   PLATFORM_OWNER_EMAILS=you@yourcompany.com
# Billing (pick one path):
#   BILLING_MODE=stripe + STRIPE_SECRET_KEY + STRIPE_WEBHOOK_SECRET
#     + NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY (amounts from lib/payments/stripeCatalog.js)
#   — or — BILLING_MODE=manual + TENVO_MANUAL_PAYMENT_* for offline billing UI
#     (+ NOWPayments keys if offering crypto checkout)
# Verify locally: bun run verify:mvp-launch && bun run build

# ═══════════════════════════════════════════════════════════════
# CACHE / REDIS (optional — see lib/cache/redis.js)
# ═══════════════════════════════════════════════════════════════
# Vercel (recommended): Upstash Redis REST — works from serverless/edge (no VPC).
# Copy UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN from Upstash Console → Details.
# Free tier: 10k cmd/s, 256 MB storage — we cache only domain index + rate limits.
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=
# ElastiCache (AWS VPC only): set REDIS_ENABLED=true on compute in the same VPC.
#   REDIS_URL=rediss://default:PASSWORD@endpoint:6379
# Disable all Redis (Next.js + Vercel Runtime Cache still apply):
# REDIS_DISABLED=true

# ═══════════════════════════════════════════════════════════════
# OPS / MAINTENANCE (optional)
# ═══════════════════════════════════════════════════════════════
# ALLOW_RUNTIME_MIGRATION=false
# MAINTENANCE_API_KEY=
# LOG_LEVEL=debug
