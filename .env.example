# TENVO — example environment (tuned for local / owner QA: flags ON, manual billing).
# Copy to `.env` or `.env.local` and replace secrets/URLs. For production, set
# NEXT_PUBLIC_DEV_FULL_FEATURES=false, BILLING_MODE=stripe (or omit), and real Stripe keys.

# ═══════════════════════════════════════════════════════════════
# FEATURE FLAGS (recommended defaults for local / owner QA)
# ═══════════════════════════════════════════════════════════════
# With the values below, UI flags are ON and `NEXT_PUBLIC_DEV_FULL_FEATURES` bypasses
# rollout gating in `isFeatureEnabledForUser()` so features match env, not ROLLOUT_CONFIG.
# Plan limits still follow `businesses.plan_tier` unless you are a platform owner (see
# PLATFORM_OWNER_EMAILS) or use BILLING_MODE=manual to change tiers in the DB without Stripe.
# Production: set NEXT_PUBLIC_DEV_FULL_FEATURES=false (or remove) and tune each flag.

# Master bypass for per-user rollout (keep true for dev; false in production)
NEXT_PUBLIC_DEV_FULL_FEATURES=true

# Enhanced business switcher (set false only to force legacy switcher if wired)
NEXT_PUBLIC_USE_ENHANCED_SWITCHER=true

# Unified dashboard + role templates + layout save + realtime widgets
NEXT_PUBLIC_ENABLE_UNIFIED_DASHBOARD=true
NEXT_PUBLIC_ENABLE_ROLE_TEMPLATES=true
NEXT_PUBLIC_ENABLE_LAYOUT_PERSISTENCE=true
NEXT_PUBLIC_ENABLE_REALTIME_UPDATES=true

# Smart defaults in forms (already on unless explicitly false; set true to be explicit)
NEXT_PUBLIC_ENABLE_SMART_DEFAULTS=true

# ═══════════════════════════════════════════════════════════════
# CORE APP (required for local dev / CI)
# ═══════════════════════════════════════════════════════════════

# PostgreSQL (pooled connection for the app)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# TLS for `pg` pool / Prisma adapter (see lib/db.js). Hosted URLs turn TLS on.
# Default without DATABASE_SSL_CA_PATH: encrypt, do not verify chain (avoids Prisma P1011 self-signed errors).
# DATABASE_SSL_STRICT=true — verify server certificate (use with public CA or set DATABASE_SSL_CA_PATH).
# DATABASE_SSL_CA_PATH=/path/to/ca.pem — PEM bundle for custom / private CA verification.
# DATABASE_SSL_DISABLE=true — force SSL off (local Postgres without TLS).
# DATABASE_SSL_INSECURE=true — legacy alias; relaxed verify is already the default when no CA file is set.

# Direct / admin connection for Prisma migrations (often same as DATABASE_URL without pooler)
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# After changing DATABASE_URL, sync the DB schema (adds billing columns, etc.):
#   bun run db:migrate
# Prisma CLI reads `DIRECT_URL` first, then `DATABASE_URL` (see prisma.config.ts).
# Use a URL your machine can reach (local Postgres, or Supabase direct host — not offline placeholders).
# See docs/DATABASE_MIGRATIONS.md

# Billing: `manual` = local/UAT — change plan_tier in Postgres / admin only, no Stripe checkout
# Production: omit or `stripe` (default in code is stripe when unset).
BILLING_MODE=manual

# Platform owner emails (comma-separated, case-insensitive). Full bypass + virtual enterprise plan.
# MUST match the email you log in with to test “everything” without plan upgrades.
PLATFORM_OWNER_EMAILS=you@example.com
# Legacy alias (merged with PLATFORM_OWNER_EMAILS):
# PLATFORM_OWNER_EMAIL_EXTRA=
# Optional single canonical display email (also merged into the owner set):
# PLATFORM_OWNER_EMAIL=

# Better Auth — use a long random string (32+ chars). Required in production.
BETTER_AUTH_SECRET=

# Public site URL — use the live host (affects SEO JSON-LD, sitemap, billing redirects, OpenRouter Referer).
# Initial launch: https://tenvo.mindscapeanalytics.com — later set to https://tenvo.com or your .org.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════
# RESEND (transactional email — marketing forms + product emails)
# ═══════════════════════════════════════════════════════════════

# Required in production for contact/demo/newsletter delivery.
RESEND_API_KEY=

# Optional: verified sender in Resend (domain must be verified in Resend dashboard).
# Example after Mindscape domain is verified: RESEND_FROM=TENVO <hello@mindscapeanalytics.com>
# RESEND_FROM=

# ═══════════════════════════════════════════════════════════════
# MARKETING ASSISTANT (floating chat on marketing pages)
# Default: Gemini first (low cost), OpenRouter second if both keys are set.
# Uses @ai-sdk/google + @openrouter/ai-sdk-provider. Do not point @ai-sdk/openai
# at OpenRouter (AI SDK 6 would call /v1/responses and return 400).
# ═══════════════════════════════════════════════════════════════

# GOOGLE_GENERATIVE_AI_API_KEY=
# Default in code: gemini-3.1-flash-lite-preview (low-cost Flash-Lite). Alternates:
# GOOGLE_GENERATIVE_AI_MODEL=gemini-flash-lite-latest
# GOOGLE_GENERATIVE_AI_MODEL=gemini-2.5-flash-lite
# Optional cheaper tier when supported: standard | flex | priority
# GOOGLE_GENERATIVE_AI_SERVICE_TIER=flex

# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini

# When BOTH keys are set: gemini (default) or openrouter first
# MARKETING_ASSISTANT_PRIMARY=gemini
# MARKETING_ASSISTANT_PRIMARY=openrouter

# Shown on registration / marketing (defaults to support@tenvo.com if unset)
# NEXT_PUBLIC_SUPPORT_EMAIL=support@tenvo.com

# Marketing forms: To MARKETING_INBOUND_EMAIL (default tenvo@mindscapeanalytics.com — received by Zeeshan Keerio
# via Mindscape mailbox / forwarding). Visitor Reply-To preserved. Requires RESEND_API_KEY.
MARKETING_INBOUND_EMAIL=tenvo@mindscapeanalytics.com
# CONTACT_INBOUND_EMAIL=  # optional; used only if MARKETING_INBOUND_EMAIL is unset

# ═══════════════════════════════════════════════════════════════
# BILLING MODE (SaaS subscription — see lib/config/billingMode.js)
# ═══════════════════════════════════════════════════════════════
# Omit or `stripe` = real Stripe. `manual` or `dev` = Postgres-only plan changes (no Stripe API).
# BILLING_MODE=manual

# ═══════════════════════════════════════════════════════════════
# STRIPE (SaaS billing + Connect + storefront payments)
# ═══════════════════════════════════════════════════════════════
# Publishable key optional until you use Stripe.js / Elements in the browser.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs (see lib/payments/stripe.js STRIPE_PRICE_IDS)
STRIPE_PRICE_STARTER_MONTHLY_PKR=
STRIPE_PRICE_GROWTH_MONTHLY_PKR=
STRIPE_PRICE_PROFESSIONAL_MONTHLY_PKR=
STRIPE_PRICE_BUSINESS_MONTHLY_PKR=

# Same tiers in USD (used when checkout passes currency=usd — see getPriceIdForPlan in lib/payments/stripe.js)
STRIPE_PRICE_STARTER_MONTHLY_USD=
STRIPE_PRICE_GROWTH_MONTHLY_USD=
STRIPE_PRICE_PROFESSIONAL_MONTHLY_USD=
STRIPE_PRICE_BUSINESS_MONTHLY_USD=

# ═══════════════════════════════════════════════════════════════
# NOWPayments (crypto invoices — lib/payments/nowpayments.js)
# ═══════════════════════════════════════════════════════════════
# NOWPAYMENTS_API_KEY=
# NOWPAYMENTS_IPN_SECRET=
# Optional: override IPN URL (default NEXT_PUBLIC_APP_URL + /api/webhooks/nowpayments)
# NOWPAYMENTS_IPN_CALLBACK_URL=

# ═══════════════════════════════════════════════════════════════
# SUPABASE (optional: storage / realtime / legacy OAuth callback)
# ═══════════════════════════════════════════════════════════════

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

