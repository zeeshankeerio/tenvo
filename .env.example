# ═══════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════

# ─── UI/UX Enhancements ───────────────────────────────────────

# Enhanced Business Switcher
# Enables the enhanced business switcher with search, favorites, and compact design
# Default: Enabled (enhanced version)
# Set to 'false' to use the original business switcher
# NEXT_PUBLIC_USE_ENHANCED_SWITCHER=false

# ─── Dashboard System ─────────────────────────────────────────

# Unified Dashboard System
# Enables consolidated dashboard with role-based templates and shared components
NEXT_PUBLIC_ENABLE_UNIFIED_DASHBOARD=false

# Role-Based Dashboard Templates
# Enables role-specific dashboard templates (Owner, Manager, Sales, Inventory, Accountant)
NEXT_PUBLIC_ENABLE_ROLE_TEMPLATES=false

# Dashboard Layout Persistence
# Enables saving and loading custom dashboard layouts
NEXT_PUBLIC_ENABLE_LAYOUT_PERSISTENCE=false

# Real-Time Dashboard Updates
# Enables WebSocket-based real-time metrics updates
NEXT_PUBLIC_ENABLE_REALTIME_UPDATES=false

# ═══════════════════════════════════════════════════════════════
# CORE APP (required for local dev / CI)
# ═══════════════════════════════════════════════════════════════

# PostgreSQL (pooled connection for the app)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# TLS for `pg` pool (see lib/db.js): hosted URLs (Neon, Supabase, sslmode=*) verify the server by default.
# DATABASE_SSL_INSECURE=true — dev-only; disables certificate verification (not for production).
# DATABASE_SSL_CA_PATH=/path/to/ca.pem — PEM bundle when the provider needs a custom CA.
# DATABASE_SSL_DISABLE=true — force SSL off (local Postgres without TLS).

# Direct / admin connection for Prisma migrations (often same as DATABASE_URL without pooler)
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# After changing DATABASE_URL, sync the DB schema (adds billing columns, etc.):
#   bun run db:migrate
# Prisma CLI reads `DIRECT_URL` first, then `DATABASE_URL` (see prisma.config.ts).
# Use a URL your machine can reach (local Postgres, or Supabase direct host — not offline placeholders).
# See docs/DATABASE_MIGRATIONS.md

# Billing: `manual` = dev/UAT — apply selected plan in DB only, no Stripe checkout/portal
# BILLING_MODE=manual

# Platform owner emails (comma-separated, case-insensitive). Same privileges as legacy admin bypass.
# PLATFORM_OWNER_EMAILS=owner@company.com,backup@company.com
# Legacy alias (merged with PLATFORM_OWNER_EMAILS):
# PLATFORM_OWNER_EMAIL_EXTRA=
# Optional single canonical display email (also merged into the owner set):
# PLATFORM_OWNER_EMAIL=

# Better Auth — use a long random string (32+ chars). Required in production.
BETTER_AUTH_SECRET=

# Public site URL (billing redirects, emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════
# STRIPE (SaaS billing + Connect + storefront payments)
# ═══════════════════════════════════════════════════════════════

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs (see lib/payments/stripe.js STRIPE_PRICE_IDS)
STRIPE_PRICE_STARTER_MONTHLY_PKR=
STRIPE_PRICE_GROWTH_MONTHLY_PKR=
STRIPE_PRICE_PROFESSIONAL_MONTHLY_PKR=
STRIPE_PRICE_BUSINESS_MONTHLY_PKR=

# Same tiers in USD (used when checkout passes currency=usd — see getPriceIdForPlan in lib/payments/stripe.js)
STRIPE_PRICE_STARTER_MONTHLY_USD=
STRIPE_PRICE_GROWTH_MONTHLY_USD=
STRIPE_PRICE_PROFESSIONAL_MONTHLY_USD=
STRIPE_PRICE_BUSINESS_MONTHLY_USD=

# ═══════════════════════════════════════════════════════════════
# SUPABASE (optional: storage / realtime / legacy OAuth callback)
# ═══════════════════════════════════════════════════════════════

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

